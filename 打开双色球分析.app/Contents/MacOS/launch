#!/bin/zsh
set -u

SCRIPT_DIR="${0:A:h}"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
PORT="8765"
LAUNCH_PATH="$ROOT/app/launch.html"
SERVER_SCRIPT="$ROOT/scripts/ssq-local-server.py"
LOG_PATH="$ROOT/data/ssq-local-server.log"

mkdir -p "$ROOT/data"

if ! command -v python3 >/dev/null 2>&1; then
  osascript -e 'display dialog "未找到 python3，无法启动双色球分析本地服务。请先安装 Python 3，或联系维护者。" buttons {"好"} default button "好" with icon caution'
  exit 1
fi

python3 "$SERVER_SCRIPT" --port "$PORT" </dev/null >>"$LOG_PATH" 2>&1 &
SERVER_PID=$!

for attempt in {1..40}; do
  if /usr/bin/curl --silent --fail --max-time 1 "http://127.0.0.1:$PORT/launch-ready.js" >/dev/null 2>&1; then
    open "http://127.0.0.1:$PORT/"
    wait "$SERVER_PID"
    exit $?
  fi
  sleep 0.1
done

open "$LAUNCH_PATH"
osascript -e 'display dialog "本地服务未能启动。请检查 data/ssq-local-server.log，或联系维护者。" buttons {"好"} default button "好" with icon caution'
kill "$SERVER_PID" >/dev/null 2>&1 || true
exit 2
